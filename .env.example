# ── GEL Inbound Shipments — environment variables ──────────────────────────
# Copy this file to .env and fill in real values.
# .env is listed in .gitignore and must NEVER be committed to GitHub.

# FileMaker Server connection
FM_HOST=your-fm-server.example.com
FM_USERNAME=your-fm-api-username
FM_PASSWORD=your-fm-api-password
FM_SIDEKICK_DB=GELSidekick.fmp12
FM_SSL_VERIFY=true          # set to false only for self-signed certs

# App
INBOUND_PORT=3005           # must not conflict with other apps on the server
NODE_ENV=production
