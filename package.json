{
  "name": "gates-inbound-shipments",
  "version": "1.0.0",
  "description": "GEL Inbound Shipments Board — React + Vite frontend, Express/FM API backend",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev:api": "node server.js",
    "dev:ui":  "vite",
    "dev":     "concurrently -n API,UI -c blue,green \"npm run dev:api\" \"npm run dev:ui\"",
    "build":   "vite build",
    "preview": "vite preview",
    "start":   "node server.js"
  },
  "dependencies": {
    "axios":   "^1.7.2",
    "dotenv":  "^16.4.5",
    "express": "^4.19.2",
    "react":   "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.0"
  }
}
